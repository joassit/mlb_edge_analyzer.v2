import logging
from datetime import date
from src.models.context import (
    GameContext, PitcherContext, TeamContext, ParkContext, WeatherContext
)

# --- AJUSTA ESTOS IMPORTS SEGÚN DÓNDE ESTÉN TUS FUNCIONES REALES ---
# Por ejemplo: from src.data.api import get_schedule, get_park_info, ...
# Si estaban en la raíz, solo importa el nombre del archivo.
from data_loader import (
    get_schedule, get_park_info, get_game_weather, 
    get_team_ops, get_bullpen_era, get_pitcher_era, 
    get_pitcher_command, get_pitcher_rest
)

# Configuración básica de logs
logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')
logger = logging.getLogger(__name__)

def build_game_context(g: dict) -> GameContext:
    """
    Transforma un diccionario de datos (API) en un objeto GameContext.
    """
    park_info = get_park_info(g["home_team_id"])
    weather = get_game_weather(park_info["lat"], park_info["lon"], g.get("game_time"))
    
    return GameContext(
        game_pk=g["game_pk"],
        game_date=date.today(),
        away_team=TeamContext(
            team_id=g["away_team_id"], 
            name=g["away_team"], 
            ops=get_team_ops(g["away_team_id"]), 
            bullpen_era=get_bullpen_era(g["away_team_id"])
        ),
        home_team=TeamContext(
            team_id=g["home_team_id"], 
            name=g["home_team"], 
            ops=get_team_ops(g["home_team_id"]), 
            bullpen_era=get_bullpen_era(g["home_team_id"])
        ),
        away_pitcher=PitcherContext(
            pitcher_id=g["away_pitcher_id"], 
            name=g["away_pitcher_name"], 
            era=get_pitcher_era(g["away_pitcher_id"]),
            k_pct=get_pitcher_command(g["away_pitcher_id"])["k_pct"],
            bb_pct=get_pitcher_command(g["away_pitcher_id"])["bb_pct"],
            days_rest=get_pitcher_rest(g["away_pitcher_id"])["days_rest"]
        ),
        home_pitcher=PitcherContext(
            pitcher_id=g["home_pitcher_id"], 
            name=g["home_pitcher_name"], 
            era=get_pitcher_era(g["home_pitcher_id"]),
            k_pct=get_pitcher_command(g["home_pitcher_id"])["k_pct"],
            bb_pct=get_pitcher_command(g["home_pitcher_id"])["bb_pct"],
            days_rest=get_pitcher_rest(g["home_pitcher_id"])["days_rest"]
        ),
        park=ParkContext(
            name=park_info["name"], 
            park_factor=park_info["park_factor"], 
            lat=park_info["lat"], 
            lon=park_info["lon"]
        ),
        weather=WeatherContext(temp_f=weather["temp_f"])
    )

def analyze_today():
    """Flujo principal de ejecución del sistema."""
    logger.info("Iniciando análisis de juegos para hoy...")
    
    try:
        games = get_schedule(date.today())
    except Exception as e:
        logger.error(f"No se pudo obtener el calendario: {e}")
        return

    for g in games:
        try:
            # 1. Construcción del contexto
            ctx = build_game_context(g)
            
            # 2. Aquí iría la llamada a tu lógica de modelos
            # result = tu_modelo.predict(ctx)
            
            logger.info(f"Juego {ctx.game_pk} ({ctx.away_team.name} vs {ctx.home_team.name}) procesado correctamente.")
            
        except Exception as e:
            logger.error(f"Error procesando el juego {g.get('game_pk')}: {e}")

if __name__ == "__main__":
    analyze_today()